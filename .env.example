# DATABASE_URL: Koneksi ke PostgreSQL. Format: postgresql://USER:PASSWORD@HOST:PORT/DATABASE
DATABASE_URL="postgresql://johndoe:mypassword@localhost:5432/mydb?schema=public"

# JWT_SECRET: Kunci rahasia untuk menandatangani token autentikasi.
JWT_SECRET="super-secret-key-change-this-in-production"

# GEMINI_API_KEY: Digunakan untuk fitur AI (opsional di masa depan).
GEMINI_API_KEY=""
