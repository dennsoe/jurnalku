// prisma/schema.prisma

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  STUDENT
  ADMIN
}

model User {
  id        String   @id @default(cuid())
  nis       String   @unique
  name      String
  password  String
  role      Role     @default(STUDENT)
  status    String   @default("ACTIVE") // ACTIVE, INACTIVE
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  entries   Entry[]
  comments  Comment[]
  reactions Reaction[]
  auditLogs AuditLog[]
  kuesionerDibuat  Kuesioner[]        @relation("KuesionerCreatedBy")
  jawabanKuesioner JawabanKuesioner[] @relation("JawabanUser")
}

model Entry {
  id        String   @id @default(cuid())
  title     String
  body      String   @db.Text
  mood      String
  moodLabel String
  ref1      String?  @db.Text
  ref2      String?  @db.Text
  ref3      String?  @db.Text
  userId    String
  user      User     @relation(fields: [userId], references: [id])
  comments  Comment[]
  reactions Reaction[]
  viewCount Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId])
}

model Comment {
  id        String   @id @default(cuid())
  body      String   @db.Text
  userId    String
  user      User     @relation(fields: [userId], references: [id])
  entryId   String
  entry     Entry    @relation(fields: [entryId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())

  @@index([entryId])
  @@index([userId])
}

model Reaction {
  id        String   @id @default(cuid())
  type      String   // e.g., "LOVE", "CLAP", "SUPPORT"
  userId    String
  user      User     @relation(fields: [userId], references: [id])
  entryId   String
  entry     Entry    @relation(fields: [entryId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())

  @@unique([userId, entryId])
  @@index([entryId])
  @@index([userId])
}

model AuditLog {
  id        String   @id @default(cuid())
  action    String   // e.g., "LOGIN", "CREATE_ENTRY", "DELETE_USER"
  details   String?  @db.Text
  ipAddress String?
  userId    String?
  user      User?    @relation(fields: [userId], references: [id])
  createdAt DateTime @default(now())

  @@index([userId])
}

// ===== KUESIONER / INTERVENSI =====

enum JenisKuesioner {
  UMUM        // Kuesioner umum / asesmen bebas
  SOSIOMETRI  // Pemetaan hubungan sosial
  DCM         // Daftar Cek Masalah
  INVENTORI   // Inventori minat/kepribadian
}

enum StatusKuesioner {
  DRAFT
  AKTIF
  TUTUP
}

enum JenisPertanyaan {
  LIKERT          // Skala 1-5
  SKALA           // Rating 1-10
  PILIHAN_GANDA   // Pilih satu opsi
  YA_TIDAK        // Boolean
  ESAI            // Teks bebas
}

model Kuesioner {
  id          String          @id @default(cuid())
  judul       String
  deskripsi   String?         @db.Text
  jenis       JenisKuesioner  @default(UMUM)
  status      StatusKuesioner @default(DRAFT)
  createdById String
  createdBy   User            @relation("KuesionerCreatedBy", fields: [createdById], references: [id])
  indikator   Indikator[]
  jawaban     JawabanKuesioner[]
  createdAt   DateTime        @default(now())
  updatedAt   DateTime        @updatedAt

  @@index([createdById])
  @@index([status])
}

model Indikator {
  id           String       @id @default(cuid())
  nama         String
  deskripsi    String?      @db.Text
  urutan       Int          @default(0)
  kuesionerId  String
  kuesioner    Kuesioner    @relation(fields: [kuesionerId], references: [id], onDelete: Cascade)
  pertanyaan   Pertanyaan[]

  @@index([kuesionerId])
}

model Pertanyaan {
  id           String          @id @default(cuid())
  teks         String          @db.Text
  jenis        JenisPertanyaan @default(LIKERT)
  urutan       Int             @default(0)
  wajib        Boolean         @default(true)
  indikatorId  String
  indikator    Indikator       @relation(fields: [indikatorId], references: [id], onDelete: Cascade)
  opsi         OpsiJawaban[]
  detailJawaban DetailJawaban[]

  @@index([indikatorId])
}

model OpsiJawaban {
  id           String     @id @default(cuid())
  teks         String
  nilai        Int        @default(0)  // nilai numerik untuk skoring
  urutan       Int        @default(0)
  pertanyaanId String
  pertanyaan   Pertanyaan @relation(fields: [pertanyaanId], references: [id], onDelete: Cascade)

  @@index([pertanyaanId])
}

model JawabanKuesioner {
  id          String         @id @default(cuid())
  kuesionerId String
  kuesioner   Kuesioner      @relation(fields: [kuesionerId], references: [id], onDelete: Cascade)
  userId      String
  user        User           @relation("JawabanUser", fields: [userId], references: [id])
  detail      DetailJawaban[]
  submittedAt DateTime       @default(now())

  @@unique([kuesionerId, userId])  // satu siswa hanya bisa submit sekali
  @@index([kuesionerId])
  @@index([userId])
}

model DetailJawaban {
  id               String           @id @default(cuid())
  jawabanId        String
  jawaban          JawabanKuesioner @relation(fields: [jawabanId], references: [id], onDelete: Cascade)
  pertanyaanId     String
  pertanyaan       Pertanyaan       @relation(fields: [pertanyaanId], references: [id])
  nilaiTeks        String?          @db.Text  // untuk ESAI
  nilaiAngka       Int?                       // untuk LIKERT, SKALA, YA_TIDAK (0/1)
  nilaiOpsiId      String?                    // untuk PILIHAN_GANDA

  @@index([jawabanId])
  @@index([pertanyaanId])
}
